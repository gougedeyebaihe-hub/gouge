#!name=Lynk & Co Auth Probe
#!desc=One-time auth capture probe for Lynk & Co on Loon
#!author=OpenAI Codex
#!homepage=https://nsloon.app/docs/

[Argument]
debugNotify=1

[Script]
http-request ^https?:\/\/h5-api\.lynkco\.com\/.* script-path=https://raw.githubusercontent.com/gougedeyebaihe-hub/gouge/main/capture.bundle.js?v=20260427f,requires-body=true,tag=lynkco-auth-probe,timeout=20,enable=true
http-response ^https?:\/\/h5-api\.lynkco\.com\/.* script-path=https://raw.githubusercontent.com/gougedeyebaihe-hub/gouge/main/capture.bundle.js?v=20260427f,requires-body=true,tag=lynkco-auth-probe-response,timeout=20,enable=true

[MITM]
hostname = h5-api.lynkco.com,h5.lynkco.com
