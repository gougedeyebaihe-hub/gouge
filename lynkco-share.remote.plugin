#!name=Lynk & Co Auto Tasks
#!desc=Capture auth state and run sign/share when a Lynk & Co token is detected | Version v20260722j
#!arguments=articleId=,debugNotify=0,shareEnabled=1,autoRunOnCapture=1,pingNotify=0,captureTraceNotify=0,signTraceNotify=1,signRequestNotify=0,signCandidateNotify=0
#!author=OpenAI Codex
#!homepage=https://nsloon.app/docs/

[Argument]
articleId=
debugNotify=0
shareEnabled=1
autoRunOnCapture=1
pingNotify=0
captureTraceNotify=0
signTraceNotify=1
signRequestNotify=0
signCandidateNotify=0

[Script]
http-request ^https?:\/\/(h5-api|h5|app-api-gw-toc)\.lynkco\.com\/.* script-path=https://raw.githubusercontent.com/gougedeyebaihe-hub/gouge/main/auto.bundle.js?v=20260722j,requires-body=true,tag=lynkco-auto-capture,timeout=90,enable=true
http-response ^https?:\/\/(h5-api|h5|app-api-gw-toc)\.lynkco\.com\/.* script-path=https://raw.githubusercontent.com/gougedeyebaihe-hub/gouge/main/auto.bundle.js?v=20260722j,requires-body=true,tag=lynkco-auto-run,timeout=90,enable=true

[MITM]
hostname = h5-api.lynkco.com,h5.lynkco.com,app-api-gw-toc.lynkco.com
